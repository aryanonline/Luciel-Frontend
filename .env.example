# =============================================================================
# Luciel Frontend — environment template (SAFE to commit; copy to .env.local)
# =============================================================================
# HARD RULE (Space Instructions §3.4): no secrets in any bundle, and no secret
# may live in a NEXT_PUBLIC_* variable. Anything prefixed NEXT_PUBLIC_ is
# inlined into the client bundle and is therefore PUBLIC. Only non-secret,
# already-public values may use that prefix.
#
# The session JWT is NEVER an env var here — it is carried by an httpOnly,
# Secure, SameSite cookie set by the backend, or held in memory only
# (Space Instructions §3.3). It is never read from localStorage/sessionStorage.
# -----------------------------------------------------------------------------

# --- The ONE adapter-selection flag (api-client, §7) -------------------------
# "mock" -> in-memory mockAdapter (no backend). "http" -> real httpAdapter.
# Swapping mock->http must require ZERO component changes.
NEXT_PUBLIC_API_ADAPTER=mock

# Public API origin used by the httpAdapter (NOT a secret — it is a public URL).
# Required only when NEXT_PUBLIC_API_ADAPTER=http.
NEXT_PUBLIC_API_BASE_URL=https://api.vantagemind.com

# Public Stripe publishable key (publishable keys are designed to be public).
# The Stripe SECRET key NEVER appears in the frontend.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Widget build (apps/widget) ----------------------------------------------
# The widget's data-plane API origin. The embed key is NOT configured here —
# it is injected at runtime by the host page's data-key attribute (§3.4).
VITE_WIDGET_API_BASE_URL=https://api.vantagemind.com
VITE_WIDGET_ADAPTER=mock
